{
  "manifest_version": 3,
  "name": "Any Language Social",
  "version": "0.1.0",
  "description": "Translate posts on X into the language you choose.",
  "permissions": ["storage"],
  "host_permissions": [
    "https://api.mymemory.translated.net/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "assets/icon16.png",
    "32": "assets/icon32.png",
    "48": "assets/icon48.png",
    "128": "assets/icon128.png"
  },
  "action": {
    "default_title": "Any Language Social",
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "assets/icon16.png",
      "32": "assets/icon32.png",
      "48": "assets/icon48.png"
    }
  },
  "content_scripts": [
    {
      "matches": [
        "https://x.com/*",
        "https://twitter.com/*"
      ],
      "js": ["content/x.js"],
      "css": ["content/x.css"],
      "run_at": "document_idle"
    }
  ]
}
